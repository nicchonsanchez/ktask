# Credenciais de OPERAÇÃO (não usadas pelo runtime do app).
#
# Copia este arquivo pra `.env.ops` (ignorado pelo git) e preenche com os
# valores reais. Os scripts em `scripts/ops/` carregam essas variáveis
# automaticamente.
#
# NUNCA commitar .env.ops nem colar essas credenciais em chat/PR.

# ----------- Hetzner Cloud -----------
# Token gerado em https://console.hetzner.cloud → Security → API Tokens.
# Usado para: reset_password, reboot, snapshot, listar servers, etc.
# Permission: Read & Write.
HCLOUD_TOKEN=

# ID do servidor de produção (encontrado em /v1/servers ou na URL do painel)
HCLOUD_SERVER_ID=127919033

# IP público do servidor — usado pra SSH
DEPLOY_HOST=178.104.220.28

# ----------- (futuro) outras credenciais de ops viriam aqui -----------
# MINIO_ADMIN_USER=
# MINIO_ADMIN_PASSWORD=
