{
	email {$LETSENCRYPT_EMAIL}
	# TLS Let's Encrypt automático
	# Logs em formato JSON vão pro stdout, docker captura
	servers {
		protocols h1 h2 h3
	}
}

# ------------- Web (Next.js) -------------
{$KTASK_WEB_DOMAIN} {
	encode zstd gzip

	# Cabeçalhos de segurança
	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	# Tudo vai pro container web
	reverse_proxy web:3000 {
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}

		# Zero-downtime durante deploy: segura a request por ate 30s tentando
		# reconectar quando o container web esta sendo trocado. Sem isso,
		# qualquer atualizacao causa 502 instantaneo por ~10s. Com isso, o
		# user ve loading prolongado mas a request completa quando o
		# container novo fica saudavel.
		lb_try_duration 30s
		lb_try_interval 250ms
	}
}

# ------------- API + WebSocket (NestJS + Socket.IO) -------------
{$KTASK_API_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		Access-Control-Allow-Credentials "true"
		-Server
	}

	# Swagger / OpenAPI: bloqueado em prod (devolve 404).
	# Documentação interativa só fica disponível em dev (localhost:4000/docs).
	# KTask hoje é uso interno; sem necessidade de expor schema publicamente.
	@docs path /docs /docs/* /docs-json
	handle @docs {
		respond "Not Found" 404
	}

	# Socket.IO path: deixa o reverse_proxy direcionar (same origin)
	# Caddy detecta automaticamente WS upgrade via headers padrão
	handle {
		reverse_proxy api:4000 {
			header_up X-Real-IP {remote_host}
			header_up X-Forwarded-Proto {scheme}
			# Timeouts maiores pra WebSocket
			transport http {
				read_timeout 0
				write_timeout 0
			}

			# Zero-downtime durante deploy (mesmo motivo do bloco web acima).
			# Importante pra API pq deploy tipicamente reinicia ktask-api e
			# qualquer chamada nesse intervalo viraria 502.
			lb_try_duration 30s
			lb_try_interval 250ms
		}
	}
}

# ------------- Storage (MinIO S3-compat para avatars/anexos) -------------
# Uploads via PUT (URL pre-assinada gerada pela API).
# Leitura publica direta via GET (bucket com policy anonima).
{$KTASK_CDN_DOMAIN} {
	encode zstd gzip

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		# Imagens publicas: cache agressivo. Uploads usam keys novas a cada vez.
		Cache-Control "public, max-age=31536000, immutable"
		-Server
	}

	# Limite generoso para upload de arquivos (Caddy default 1GB, ajustado pra ficar explicito)
	request_body {
		max_size 10MB
	}

	reverse_proxy minio:9000 {
		header_up Host {host}
		header_up X-Real-IP {remote_host}
		header_up X-Forwarded-Proto {scheme}
	}
}
