# ===== KTask produção — template =====
# Copia para infra/prod.env no servidor (nunca committar):
#   cp infra/prod.env.example infra/prod.env
# Depois preenche os valores sensíveis.

# ----- Imagem ativa em prod (atualizada pelo workflow Deploy) -----
# O workflow exporta IMAGE_TAG=<sha> ao fazer pull/up. Aqui fica o default
# pra rollback manual: trocar pra um <sha> antigo + docker compose up -d.
IMAGE_TAG=latest

# ----- Domínios -----
KTASK_WEB_DOMAIN=ktask.agenciakharis.com.br
KTASK_API_DOMAIN=api.ktask.agenciakharis.com.br
KTASK_CDN_DOMAIN=cdn.ktask.agenciakharis.com.br
LETSENCRYPT_EMAIL=contato@nicchon.com

# ----- URLs públicas (pro Next.js build) -----
NEXT_PUBLIC_API_URL=https://api.ktask.agenciakharis.com.br
NEXT_PUBLIC_WS_URL=wss://api.ktask.agenciakharis.com.br

# ----- CORS (onde o front roda) -----
CORS_ORIGINS=https://ktask.agenciakharis.com.br

# ----- Postgres -----
POSTGRES_DB=ktask
POSTGRES_USER=ktask
# Gera com: openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ----- Auth (JWT) -----
# Gera com: openssl rand -hex 32
JWT_ACCESS_SECRET=CHANGE_ME_64_hex_chars
JWT_REFRESH_SECRET=CHANGE_ME_64_hex_chars_different

# ----- Criptografia de integrações (Evolution API etc) -----
# Gera com: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=CHANGE_ME_64_hex_chars

# ----- E-mail (servidor Napoleon — agenciakharis.com.br) -----
# Porta 465 + SSL direto (SMTP_SECURE=true) ou 587 + STARTTLS (SMTP_SECURE=false).
# Em prod usamos 465+SSL.
EMAIL_FROM=Kharis <no-reply@agenciakharis.com.br>
SMTP_HOST=mail.agenciakharis.com.br
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=no-reply@agenciakharis.com.br
# Coloca a senha real direto no infra/prod.env da VM (NAO commita aqui).
SMTP_PASS=CHANGE_ME_smtp_password

# ----- Evolution API (WhatsApp, só ativa quando for configurar automações v1) -----
EVOLUTION_DEFAULT_URL=
EVOLUTION_DEFAULT_API_KEY=

# ----- Storage (MinIO S3-compat, serve avatars e anexos) -----
# Senha root do MinIO — gera com: openssl rand -hex 24
MINIO_ROOT_USER=ktask
MINIO_ROOT_PASSWORD=CHANGE_ME_strong_minio_password
S3_BUCKET=ktask
S3_REGION=us-east-1

# ----- Sentry (observabilidade, opcional) -----
SENTRY_DSN=
