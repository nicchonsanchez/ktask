# URL da API NestJS
NEXT_PUBLIC_API_URL=http://localhost:4000

# URL do WebSocket (mesmo host da API)
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Nome do app (para UI). Normalmente fica o default KTask.
NEXT_PUBLIC_APP_NAME=KTask

# URL pública do app (usada em metadata/OG/canonical). Em dev pode ficar
# o localhost; em prod usar o domínio real (ex: https://ktask.agenciakharis.com.br).
NEXT_PUBLIC_APP_URL=http://localhost:3000
