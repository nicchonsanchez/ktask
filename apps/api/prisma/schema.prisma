// KTask — Prisma schema
//
// Modelos completos para MVP (Kanban: quadros, listas, cards, labels,
// checklists, anexos, comentários, activity log, notifications).
// Ver `tarefas-md/03-entidades-e-dominio.md` para o modelo de domínio.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== Enums ====================

enum OrgRole {
  OWNER
  ADMIN
  GESTOR
  MEMBER
  GUEST
}

enum OrgPlan {
  INTERNAL
  FREE
  PRO
  ENTERPRISE
}

enum BoardRole {
  ADMIN
  EDITOR
  COMMENTER
  VIEWER
}

enum BoardVisibility {
  PRIVATE
  ORGANIZATION
}

enum CardOrdering {
  MANUAL
  TIME_IN_LIST
  TIME_INTERACTION
  ALPHABETICAL
  COMPLETION_DATE
  CREATION_DATE
}

enum TimeEntrySource {
  TIMER
  MANUAL
}

enum Priority {
  NONE
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum AttachmentKind {
  FILE
  LINK
  IMAGE
}

enum NotificationType {
  MENTION
  ASSIGNED
  DUE_SOON
  COMMENT
  SLA_BREACH
  AUTOMATION
  /// Lembrete automatico ou inicial de aprovacao pendente (cron de
  /// ApprovalRemindersService ou request inicial).
  APPROVAL_REQUEST
  CUSTOM
}

enum ActivityType {
  CARD_CREATED
  CARD_UPDATED
  CARD_MOVED
  CARD_ARCHIVED
  CARD_RESTORED
  CARD_TRASHED
  CARD_RESTORED_FROM_TRASH
  CARD_DELETED_PERMANENTLY
  LIST_TRASHED
  LIST_RESTORED_FROM_TRASH
  LIST_DELETED_PERMANENTLY
  CARD_COMPLETED
  CARD_UNCOMPLETED
  CARD_ASSIGNED
  CARD_UNASSIGNED
  CARD_LEAD_CHANGED
  CARD_PARENT_LINKED
  CARD_PARENT_UNLINKED
  TIME_ENTRY_STARTED
  TIME_ENTRY_STOPPED
  TIME_ENTRY_CREATED
  TIME_ENTRY_UPDATED
  TIME_ENTRY_DELETED
  LABEL_ADDED
  LABEL_REMOVED
  COMMENT_ADDED
  COMMENT_EDITED
  COMMENT_DELETED
  CHECKLIST_CREATED
  CHECKLIST_RENAMED
  CHECKLIST_DELETED
  CHECKLIST_ITEM_CREATED
  CHECKLIST_ITEM_RENAMED
  CHECKLIST_ITEM_DELETED
  CHECKLIST_ITEM_DONE
  CHECKLIST_ITEM_UNDONE
  ATTACHMENT_ADDED
  ATTACHMENT_REMOVED
  LIST_CREATED
  LIST_UPDATED
  LIST_ARCHIVED
  BOARD_CREATED
  BOARD_UPDATED
  BOARD_ARCHIVED
  BOARD_DELETED
  MEMBER_JOINED_BOARD
  MEMBER_LEFT_BOARD
  BOARD_VIEWED_IMPLICIT
  CARD_CONTACT_LINKED
  CARD_CONTACT_UNLINKED
  CONTACT_CREATED
  CONTACT_UPDATED
  CONTACT_DELETED
  CONTACT_LINKED_TO_USER
  CONTACT_UNLINKED_FROM_USER
  MEMBER_NAME_CHANGED
  MEMBER_EMAIL_CHANGE_REQUESTED
  MEMBER_PHONE_CHANGED
  MEMBER_PASSWORD_RESET_FORCED
  MEMBER_PASSWORD_RESET_SENT
  MEMBER_ROLE_CHANGED
  MEMBER_SUSPENDED
  MEMBER_UNSUSPENDED
  MEMBER_REMOVED
}

enum AutomationTrigger {
  CARD_ENTERED
  CARD_LEFT
  TIME_IN_LIST
  TIME_NO_INTERACTION
  DUE_DATE_TODAY
  DUE_DATE_OVERDUE
  CARD_APPROVED // CardApproval termina como APPROVED
  CARD_REJECTED // CardApproval termina como REJECTED
  CHECKLIST_ITEM_DONE // ChecklistItem marcado como done (escopo: item específico)
  CHECKLIST_COMPLETED // todos os items de um Checklist marcados (escopo: checklist específico)
}

enum AutomationActionType {
  INSERT_TAGS
  REMOVE_TAGS
  INSERT_CHECKLIST_ITEMS
  INSERT_CHECKLIST_GROUP
  SET_CARD_STATUS
  FILL_FIELDS
  SAVE_DESCRIPTION_VERSION
  SET_LEAD
  ADD_TEAM
  POST_COMMENT
  CREATE_CHILD_CARD
  SEND_EMAIL
  SEND_WHATSAPP
  LINK_FLOW
  UNLINK_FLOW
  UPDATE_FLOW_POSITION
  MOVE_CARD // doc 50: move card pra outra coluna do mesmo board
  FLAG_DUE_TODAY
  FLAG_OVERDUE
  SET_PRIVACY
}

enum AutomationRunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
  SKIPPED
  /// Sweeper marcou após run ficar em RUNNING por mais que o teto.
  /// Indica que o processo morreu/timeoutou durante a execução.
  ABANDONED
}

/// Escopo do trigger persistido na outbox: identifica em qual entidade
/// o evento foi disparado. Mapeia 1:1 com os triggers da Automation.
enum AutomationOutboxScope {
  LIST            // CARD_ENTERED / CARD_LEFT / CARD_APPROVED / CARD_REJECTED → escopo = list
  CHECKLIST       // CHECKLIST_COMPLETED → escopo = checklist
  CHECKLIST_ITEM  // CHECKLIST_ITEM_DONE → escopo = checklistItem
}

/// Tipo do envio de uma cobranca de aprovacao. Distingue o que foi
/// disparado automaticamente (cron) do que veio de acao humana.
enum ApprovalDispatchKind {
  /// Envio inicial — quando a approval foi criada (request).
  INITIAL
  /// Resend manual — alguem clicou "Reenviar" no card.
  RESEND
  /// Lembrete automatico — cron de ApprovalRemindersService.
  REMINDER
}

/// Canal pelo qual a cobranca foi enviada.
enum ApprovalDispatchChannel {
  WHATSAPP
  IN_APP
}

// ==================== Tenant / Auth ====================

model User {
  id                        String    @id @default(cuid())
  email                     String    @unique
  emailVerifiedAt           DateTime?
  passwordHash              String
  name                      String
  avatarUrl                 String?
  /// E.164 sem o '+', ex: 5521988887777. Usado pra notificar aprovações
  /// via WhatsApp quando o user é escolhido como reviewer.
  phone                     String?
  /// Quando true, usa Evolution API pra mandar notificação de aprovação
  /// pendente pro `phone` do user (além das notificações in-app/push).
  notifyApprovalsOnWhatsApp Boolean   @default(false)
  locale                    String    @default("pt-BR")
  timezone                  String    @default("America/Sao_Paulo")
  twoFactorSecret           String?
  twoFactorEnabled          Boolean   @default(false)
  failedLoginCount          Int       @default(0)
  lastFailedAt              DateTime?
  lockedUntil               DateTime?
  /// Suspensao admin: bloqueia login + uso da API mas preserva dados
  /// (diferente de deletedAt). Login retorna 403 com motivo amigavel.
  /// Reverter via PATCH /admin/users/:id/suspend (toggle).
  suspendedAt               DateTime?
  suspendedReason           String?
  /// Pendencia de troca de email: novo email aguardando confirmacao via
  /// link enviado pro proprio user. Quando user clica, sistema move
  /// pendingEmail -> email e limpa pendingEmail. Anti-sequestro.
  pendingEmail              String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  deletedAt                 DateTime?

  memberships               Membership[]
  sessions                  Session[]
  invitationsSent           Invitation[]           @relation("InvitationCreator")
  boardMemberships          BoardMember[]
  boardsCreated             Board[]                @relation("BoardCreator")
  boardFavorites            BoardFavorite[]
  cardsCreated              Card[]                 @relation("CardCreator")
  cardsCompleted            Card[]                 @relation("CardCompletedBy")
  cardsLeading              Card[]                 @relation("CardLead")
  cardsDeleted              Card[]                 @relation("CardDeletedBy")
  listsDeleted              List[]                 @relation("ListDeletedBy")
  cardAssignments           CardMember[]
  commentsAuthored          Comment[]
  commentReactions          CommentReaction[]
  attachmentsUploaded       Attachment[]
  activities                Activity[]             @relation("ActivityActor")
  notifications             Notification[]
  approvalDispatches        ApprovalDispatchLog[]
  timeEntries               TimeEntry[]
  checklistItemsAssigned    ChecklistItem[]        @relation("ChecklistItemAssignee")
  checklistItemsDone        ChecklistItem[]        @relation("ChecklistItemDoneBy")
  cardVisits                CardVisit[]
  tasksAssigned             Task[]                 @relation("TaskAssignee")
  tasksCreated              Task[]                 @relation("TaskCreator")
  tasksDone                 Task[]                 @relation("TaskDoneBy")
  automationsCreated        Automation[]           @relation("AutomationCreator")
  cardPresencesCompleted    CardPresence[]         @relation("CardPresenceCompletedBy")
  pushSubscriptions         PushSubscription[]
  checklistTemplatesCreated ChecklistTemplate[]    @relation("ChecklistTemplateCreator")
  approvalsRequested        CardApproval[]         @relation("ApprovalRequester")
  approvalsDecided          CardApproval[]         @relation("ApprovalDecider")
  approvalsReverted         CardApproval[]         @relation("ApprovalReverter")
  approvalsCanceled         CardApproval[]         @relation("ApprovalCanceler")
  approvalReviews           CardApprovalReviewer[] @relation("CardApprovalReviewer")
  messageTemplates          MessageTemplate[]
  passwordResetTokens       PasswordResetToken[]
  /// Contact vinculado (1:1 via Contact.userId). Quando existe, no CRM
  /// o User aparece como entrada de Contact com identidade vinda do User.
  linkedContact             Contact?               @relation("ContactUser")

  @@index([email])
}

/// Doc 43: token de recuperacao de senha. Gerado quando user pede
/// reset; expira em 1h; single-use (usedAt). Token raw vai pro email,
/// hash sha256 fica no DB.
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  /// IP e UA de quem solicitou — auditoria + detectar abuso.
  requestIp String?
  userAgent String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([expiresAt])
}

model Organization {
  id                           String    @id @default(cuid())
  name                         String
  slug                         String    @unique
  logoUrl                      String?
  timezone                     String    @default("America/Sao_Paulo")
  locale                       String    @default("pt-BR")
  plan                         OrgPlan   @default(INTERNAL)
  /// Counter sequencial pra gerar Card.shortCode na criacao. Incrementa
  /// atomicamente via UPDATE Postgres dentro da mesma transacao da
  /// criacao do card (evita race). Importadores (ex: CSV Ummense) podem
  /// gravar shortCodes literais (ex: "20250409000751") sem mexer aqui.
  cardSequence                 Int       @default(0)
  /// Quando true, qualquer move/link/unlink de CardPresence dispara
  /// avaliacao do status do Card:
  ///   - Se TODAS as presences ativas estao em coluna isFinalList=true
  ///     E status nao eh CANCELED → marca COMPLETED.
  ///   - Caso reverso (alguma presence saiu de final e status era
  ///     COMPLETED) → volta pra ACTIVE.
  /// Mantem CANCELED imutavel. Default false (opt-in por Org).
  autoCompleteCardWhenAllFinal Boolean   @default(false)

  /// Settings de lembretes automáticos de aprovação pendente. Quando
  /// `approvalReminderEnabled = false` (default), cron pula a org.
  /// Quando ativo, cron a cada 30min envia lembretes consolidados
  /// (1 msg/reviewer com lista de approvals pendentes dele) via
  /// WhatsApp + notificação in-app, respeitando janela horária BRT
  /// (seg-sex, hourStart-hourEnd). Cada lembrete incrementa
  /// `CardApproval.reminderCount`; para após `maxAttempts`.
  approvalReminderEnabled       Boolean  @default(false)
  /// Intervalo em horas. Aceita decimal (0.5 = 30min). Cron roda a cada
  /// 30min, entao 0.5 eh o piso pratico.
  approvalReminderIntervalHours Float    @default(4)
  /// Hora de início da janela útil (0-23, BRT). Default 8h.
  approvalReminderHourStart     Int      @default(8)
  /// Hora de fim da janela útil (0-23, BRT). Default 18h.
  approvalReminderHourEnd       Int      @default(18)
  /// Cap de lembretes por approval — após atingir, para. Default 5.
  approvalReminderMaxAttempts   Int      @default(5)
  /// Quando true, ignora `maxAttempts` E o cap de idade (30 dias) —
  /// envia eternamente até alguem decidir/cancelar. Usar com cautela:
  /// approval esquecida pra sempre vira spam pro reviewer.
  approvalReminderUnlimited     Boolean  @default(false)

  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt
  deletedAt                    DateTime?

  memberships        Membership[]
  invitations        Invitation[]
  boards             Board[]
  lists              List[]
  labels             Label[]
  activities         Activity[]
  timeEntries        TimeEntry[]
  tasks              Task[]
  automations        Automation[]
  checklistTemplates ChecklistTemplate[]
  cardApprovals      CardApproval[]
  contacts           Contact[]
  messageTemplates   MessageTemplate[]
  importMappings     OrgImportMapping[]
  managementBoards   ManagementBoard[]

  @@index([slug])
}

model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
  @@index([userId])
}

model Invitation {
  id             String    @id @default(cuid())
  organizationId String
  email          String
  /// Telefone opcional pra disparar convite tambem via WhatsApp (doc 35).
  /// Formato livre (vai ser sanitizado pra E.164 antes do envio).
  phone          String?
  role           OrgRole   @default(MEMBER)
  token          String    @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  userAgent  String?
  ip         String?
  /// True quando o user marcou "Permanecer logado" no login. Preservado
  /// nas rotações de refresh — sessão curta (1d) só vira longa (90d) se
  /// o user re-logar marcando o checkbox.
  rememberMe Boolean   @default(true)
  createdAt  DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
}

// ==================== Boards ====================

model Board {
  id                    String          @id @default(cuid())
  organizationId        String
  name                  String
  description           String?
  color                 String?
  icon                  String?
  visibility            BoardVisibility @default(PRIVATE)
  isArchived            Boolean         @default(false)
  cardOrdering          CardOrdering    @default(MANUAL)
  inheritTeamOnNewCards Boolean         @default(false)
  createdById           String
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  organization            Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy               User                     @relation("BoardCreator", fields: [createdById], references: [id])
  lists                   List[]
  labels                  Label[]
  members                 BoardMember[]
  cards                   Card[]
  automations             Automation[]
  cardPresences           CardPresence[]
  favorites               BoardFavorite[]
  managementColumnSources ManagementColumnSource[]

  @@index([organizationId, isArchived])
}

/// Doc 36: favorito de fluxo por usuario. Lista em /quadros separa
/// favoritados no topo + alfabetico em ambos os grupos.
model BoardFavorite {
  userId      String
  boardId     String
  favoritedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@id([userId, boardId])
  @@index([userId])
}

model BoardMember {
  id        String    @id @default(cuid())
  boardId   String
  userId    String
  role      BoardRole
  createdAt DateTime  @default(now())

  board Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
  @@index([userId])
}

model List {
  id             String   @id @default(cuid())
  organizationId String // denormalizado: acelera filtros e futura RLS
  boardId        String
  name           String
  position       Float
  color          String?
  icon           String?
  wipLimit       Int?
  slaMinutes     Int?
  /// Doc 42: coluna marcada como Finalizado/Concluido — espelho do is_final
  /// do Ummense. UI trata como faixa especial expansivel a direita do board.
  /// MAX 1 por board (constraint via partial unique index custom — migration
  /// 20260508120000_unique_final_list_per_board). ListsService faz swap
  /// idempotente no update pra preservar a invariante.
  isFinalList    Boolean  @default(false)
  /// Doc 42: coluna marcada como Backlog (espelho do is_backlog do Ummense).
  /// UI trata como faixa expansivel a esquerda. MIN 1 por board (ListsService
  /// ensureBacklogList + bloqueio no archive da ultima). Multiplas permitidas
  /// — caso de uso "INFORMAÇÕES" + "Backlog" coexistindo.
  isBacklog      Boolean  @default(false)
  isArchived     Boolean  @default(false)
  /// Soft delete (lixeira). Mesma semantica de Card.deletedAt. Restaurar
  /// uma lista NAO ressuscita os cards dela — cada card tem ciclo proprio.
  deletedAt      DateTime?
  deletedById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization               Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  board                      Board                    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  deletedBy                  User?                    @relation("ListDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  cards                      Card[]
  automations                Automation[]
  cardPresences              CardPresence[]
  defaultApproveForApprovals CardApproval[]           @relation("ApprovalDefaultApproveList")
  defaultRejectForApprovals  CardApproval[]           @relation("ApprovalDefaultRejectList")
  managementColumnSources    ManagementColumnSource[]

  @@index([organizationId])
  @@index([boardId, position])
  @@index([organizationId, deletedAt])
}

// ==================== Cards ====================

/// Doc 25: niveis de privacidade do card. V1 com 2 niveis; V2 pode
/// expandir pros 4 do Ummense (TEAM_VIEW, LEAD_ONLY) se precisar.
enum CardPrivacy {
  PUBLIC
  TEAM_ONLY
}

/// Doc 42: status do card, ortogonal a coluna onde esta. Espelha o
/// modelo do Ummense — um card "ACTIVE" pode estar na coluna
/// "Finalizado" (isFinalList) e vice-versa. Status muda
/// independentemente de drag-and-drop entre colunas.
enum CardStatus {
  ACTIVE // padrao — em fluxo normal de trabalho
  COMPLETED // concluido (substitui o uso isolado de completedAt)
  WAITING // pausado, aguardando algo externo (cliente, fornecedor)
  CANCELED // cancelado, nao sera feito
}

model Card {
  id                String      @id @default(cuid())
  organizationId    String // denormalizado: acelera filtros e futura RLS
  /// Identificador curto humano-legivel ("#412"), unico POR Org.
  /// Gerado sequencial via Organization.cardSequence pra cards novos;
  /// importadores podem gravar valores arbitrarios (ex: "20250409000751"
  /// preservando ID do Ummense). Indexado pra resolver lookups #N -> id.
  /// NOT NULL desde 2026-05-21 pra fechar o gap do @@unique composto —
  /// Postgres trata NULLs como distintos, permitindo multiplos cards sem
  /// shortCode na mesma Org. Helper de criacao sempre seta; importador
  /// tambem. Se algum dia precisar permitir null de novo, mudar tambem o
  /// unique pra partial WHERE shortCode IS NOT NULL.
  shortCode         String
  /// Doc 25: PUBLIC (default) = todos do board veem. TEAM_ONLY = so
  /// lider + CardMember veem (OWNER/ADMIN/GESTOR da Org bypass).
  privacy           CardPrivacy @default(PUBLIC)
  /// Doc 42: status ortogonal a coluna. completedAt continua como
  /// timestamp de "quando virou COMPLETED" (auto-set ao mudar status).
  status            CardStatus  @default(ACTIVE)
  boardId           String
  listId            String
  title             String
  description       Json? // ProseMirror / Tiptap JSON (MVP usa subset simples)
  position          Float
  /// Cor decorativa escolhida pelo user (1 de 8 valores: slate, rose,
  /// orange, amber, emerald, sky, violet, pink) ou null pra "sem cor".
  /// Substituiu o sistema de Priority do card (V2 do design 2026-05-08):
  /// agrupamento visual livre em vez de escala semantica de urgencia.
  /// ChecklistItem.priority continua existindo (escala real pra Home).
  cardColor         String?
  /// Doc 47: flag visual setado por automation (FLAG_OVERDUE/FLAG_DUE_TODAY).
  /// Valores: 'orange' | 'yellow' | 'pink' | 'red' | null. Espelha cores
  /// que o Ummense usa nos bg_color (orange1, yellow1, pink1) — render
  /// no card-item como faixa colorida no topo. Limpado quando o card
  /// muda de coluna (event CARD_MOVED no engine) — alerta nao "vaza"
  /// pra nova coluna.
  flagColor         String?
  /// Quando o flag foi setado. Usado pra ordenacao/exibicao.
  flagAt            DateTime?
  coverAttachmentId String?
  startDate         DateTime?
  dueDate           DateTime?
  completedAt       DateTime?
  completedById     String?
  estimateMinutes   Int?
  isArchived        Boolean     @default(false)
  /// Soft delete (lixeira). Quando != null, card esta na lixeira e fica
  /// invisivel pra todos os listings normais (filtro deletedAt: null em
  /// todas as queries). Auto-purge fisico apos 90 dias via cron BullMQ.
  /// Restaurar = setar deletedAt = null. Hard delete via deletePermanent
  /// agora exige deletedAt != null e role OWNER/ADMIN.
  deletedAt         DateTime?
  deletedById       String?
  parentCardId      String?
  createdById       String
  leadId            String? // Líder do card: default = createdBy, pode trocar manualmente ou via automação
  enteredListAt     DateTime    @default(now())
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  board          Board           @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list           List            @relation(fields: [listId], references: [id], onDelete: Cascade)
  createdBy      User            @relation("CardCreator", fields: [createdById], references: [id])
  completedBy    User?           @relation("CardCompletedBy", fields: [completedById], references: [id])
  deletedBy      User?           @relation("CardDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  lead           User?           @relation("CardLead", fields: [leadId], references: [id], onDelete: SetNull)
  parent         Card?           @relation("Subtasks", fields: [parentCardId], references: [id], onDelete: SetNull)
  children       Card[]          @relation("Subtasks")
  cover          Attachment?     @relation("CardCover", fields: [coverAttachmentId], references: [id], onDelete: SetNull)
  members        CardMember[]
  labels         CardLabel[]
  checklists     Checklist[]
  attachments    Attachment[]    @relation("CardAttachments")
  comments       Comment[]
  activities     Activity[]
  timeEntries    TimeEntry[]
  visits         CardVisit[]
  automationRuns AutomationRun[]
  presences      CardPresence[]
  approvals      CardApproval[]
  contacts       CardContact[]

  @@unique([organizationId, shortCode])
  @@index([organizationId])
  @@index([boardId, isArchived])
  @@index([boardId, completedAt])
  @@index([listId, position])
  @@index([dueDate])
  /// Index pra TrashService listar/contar + cron de auto-purge.
  @@index([organizationId, deletedAt])
}

/// Presença de um card em um fluxo (board). Card pode estar em N fluxos
/// simultaneamente, cada um com sua coluna atual e status de finalização
/// independente. A presença "primária" é aquela com boardId == Card.boardId
/// (durante a transição; ainda não removemos os campos legacy do Card pra
/// evitar quebrar leituras existentes).
///
/// Backfill inicial: 1 presença por card existente, espelhando seus campos.
/// Plano completo em tarefas-md/13-cards-multi-fluxo.md.
model CardPresence {
  cardId        String
  boardId       String
  listId        String
  position      Float
  completedAt   DateTime?
  completedById String?
  addedAt       DateTime  @default(now())
  removedAt     DateTime? // soft-delete pra "desvincular" mantendo histórico

  card        Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  board       Board @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list        List  @relation(fields: [listId], references: [id], onDelete: Cascade)
  completedBy User? @relation("CardPresenceCompletedBy", fields: [completedById], references: [id], onDelete: SetNull)

  @@id([cardId, boardId])
  @@index([boardId, listId, position])
  @@index([boardId, completedAt])
  @@index([boardId, removedAt])
}

/// Papel do usuário em relação ao card.
/// MEMBER (default): executor — quem trabalha no card.
/// REVIEWER: revisor/cliente — não executa, apenas aprova/reprova etapas
///   via CardApproval. Pode ser GUEST na Org (acesso só pra aprovações).
enum CardMemberRole {
  MEMBER
  REVIEWER
}

model CardMember {
  cardId String
  userId String
  role   CardMemberRole @default(MEMBER)
  card   Card           @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([cardId, userId])
}

// ==================== Card Approvals ====================

enum ApprovalStatus {
  PENDING // aguardando decisão de algum reviewer
  APPROVED // decidida como aprovada
  REJECTED // decidida como reprovada (com nota obrigatória)
  REVERTED // foi decidida e depois desfeita pelo próprio reviewer (janela 5min)
  CANCELED // pedido cancelado pelo requester/admin enquanto estava PENDING
}

/// Pedido de aprovação de um card por 1+ revisores.
///
/// Fluxo:
///   1. Membro do card pede aprovação (POST /cards/:id/approvals) escolhendo
///      reviewers (users internos ou phones externos com link tokenizado).
///   2. PENDING até alguém decidir (modelo "primeiro a votar ganha").
///   3. Decisão: APPROVED ou REJECTED. Reprovação obriga `note`.
///   4. Engine de automações recebe trigger CARD_APPROVED ou CARD_REJECTED.
///      Default fallback `defaultOnApproveListId`/`defaultOnRejectListId`
///      move o card mesmo sem automação configurada.
///   5. Sujeito a undo dentro de 5min pelo próprio decisor (ou
///      OWNER/ADMIN/GESTOR), desde que nenhuma ação humana tenha tocado
///      nos side-effects (ações de automação não bloqueiam).
model CardApproval {
  id                      String         @id @default(cuid())
  cardId                  String
  organizationId          String // denormalizado pra acelerar queries multi-tenant
  requestedById           String
  status                  ApprovalStatus @default(PENDING)
  requestedAt             DateTime       @default(now())
  decidedAt               DateTime?
  decidedById             String? // qual user decidiu (um dos reviewers internos OU null se decidido por token externo)
  decidedByExternalName   String? // nome do reviewer externo que decidiu (quando phone-only)
  note                    String? // nota da decisão; obrigatória pra REJECTED
  defaultOnApproveListId  String? /// @deprecated — use defaultOnApproveTargets. Mantido pra compat com pedidos criados antes do suporte multi-fluxo.
  defaultOnRejectListId   String? /// @deprecated — use defaultOnRejectTargets. Mesmo motivo.
  /// Lista de destinos por board pra cards multi-fluxo. Shape:
  ///   `[{ boardId: string, listId: string }, ...]`
  /// Cada entry significa "ao APROVAR, mover este card pra esta lista
  /// neste board". Boards onde o card está presente mas não estão na
  /// lista permanecem inalterados. Suporta o caso típico do KTask:
  /// card em N fluxos, operador escolhe destino por fluxo (ou "não mover").
  defaultOnApproveTargets Json?
  /// Idem pra REPROVAR.
  defaultOnRejectTargets  Json?
  /// Acoes alem do move ao APROVAR. Shape:
  /// { addTagIds: string[], removeTagIds: string[] }
  onApproveActions        Json?
  /// Idem pra REPROVAR.
  onRejectActions         Json?
  /// JSON com side-effects executados pela decisão. Usado pra rollback no undo.
  /// Shape: { automationRunIds: string[], movedFromListId?: string,
  ///          createdChecklistItemIds?: string[], createdCommentIds?: string[],
  ///          addedLabelIds?: string[] }
  sideEffects             Json?
  revertedAt              DateTime?
  revertedById            String? // user que desfez (decidedById ou ADMIN+)
  revertReason            String?
  /// Mensagem original digitada pelo requester (campo `message` do request).
  /// Persistida pra que o reenvio (resend) use o mesmo texto que o cliente
  /// já viu da primeira vez. Null em pedidos pré-migration.
  message                 String?
  canceledAt              DateTime?
  canceledById            String? // user que cancelou (requester OU OWNER/ADMIN/GESTOR)
  cancelReason            String?
  /// Timestamp do envio de WhatsApp/notificacao mais recente pros reviewers.
  /// Usado pra rate-limit do resend (cooldown 30s) e exibicao na UI.
  lastNotifiedAt          DateTime?
  /// Contador de envios (initial + N resends). Usado pra cap diario do resend.
  notifyCount             Int            @default(0)
  /// Override: desabilita lembrete automatico SOMENTE pra esta approval.
  /// Default false = usa setting da org. Util pra aprovacoes urgentes ou
  /// aprovacoes onde o requester decidiu cobrar manualmente.
  reminderDisabled        Boolean        @default(false)
  /// Override do intervalo em horas (somente esta approval). Null = usa
  /// Organization.approvalReminderIntervalHours. Aceita decimal (0.5 = 30min).
  reminderIntervalHoursOverride Float?
  /// Quantos lembretes automaticos ja foram enviados pra esta approval.
  /// Quando atinge Organization.approvalReminderMaxAttempts, para.
  reminderCount           Int            @default(0)
  /// Quando o ultimo lembrete automatico foi enviado (diferente de
  /// lastNotifiedAt, que conta initial + resends manuais).
  lastReminderAt          DateTime?
  createdAt               DateTime       @default(now())
  updatedAt               DateTime       @updatedAt

  card               Card                   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  organization       Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  requestedBy        User                   @relation("ApprovalRequester", fields: [requestedById], references: [id])
  decidedBy          User?                  @relation("ApprovalDecider", fields: [decidedById], references: [id], onDelete: SetNull)
  revertedBy         User?                  @relation("ApprovalReverter", fields: [revertedById], references: [id], onDelete: SetNull)
  canceledBy         User?                  @relation("ApprovalCanceler", fields: [canceledById], references: [id], onDelete: SetNull)
  defaultApproveList List?                  @relation("ApprovalDefaultApproveList", fields: [defaultOnApproveListId], references: [id], onDelete: SetNull)
  defaultRejectList  List?                  @relation("ApprovalDefaultRejectList", fields: [defaultOnRejectListId], references: [id], onDelete: SetNull)
  reviewers          CardApprovalReviewer[]
  dispatches         ApprovalDispatchLog[]

  @@index([cardId])
  @@index([organizationId, status, requestedAt])
  @@index([status])
}

/// Cada reviewer atribuído a uma CardApproval (modelo "primeiro a votar ganha").
/// XOR: ou `userId` (reviewer interno autenticado), ou `phone`+`externalName`
/// (reviewer externo que recebe link tokenizado via WhatsApp).
model CardApprovalReviewer {
  id           String    @id @default(cuid())
  approvalId   String
  userId       String? // interno (preenchido se foi escolhido um membro da Org)
  phone        String? // E.164 sem '+' (preenchido se foi número avulso)
  externalName String? // nome de exibição quando phone-only
  /// Token random pra acesso à página pública /aprovar/:token. Sempre presente.
  /// Mesmo reviewers internos podem usar (link no WhatsApp/email funciona sem login).
  accessToken  String    @unique
  expiresAt    DateTime // requestedAt + 7d default
  notifiedAt   DateTime?
  createdAt    DateTime  @default(now())

  approval CardApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  user     User?        @relation("CardApprovalReviewer", fields: [userId], references: [id], onDelete: Cascade)

  @@index([approvalId])
  @@index([userId])
  @@index([accessToken])
}

// ==================== Contacts (CRM lite) ====================

enum ContactType {
  PERSON
  COMPANY
}

/// Contato externo da Org (cliente, fornecedor, parceiro). Vinculado N:N
/// a cards via CardContact. Pessoas podem ter parent=Empresa pra
/// hierarquia B2B; empresas tem parentId=null sempre.
///
/// Cross-reference com User: se email ou phone bate com algum User da Org,
/// o frontend exibe link "ver como membro". Match feito on-demand, nao
/// guardamos FK pra deixar entidades independentes.
model Contact {
  id             String      @id @default(cuid())
  organizationId String
  type           ContactType
  name           String
  email          String?
  phone          String? // formato livre; armazena como digitado
  document       String? // CPF/CNPJ
  note           String? // observacoes internas
  /// Hierarquia: pessoa (PERSON) pode estar vinculada a uma empresa (COMPANY).
  /// Empresas sempre tem parentId=null (validado no service).
  parentId       String?
  /// Vínculo opcional a um User da Org. Quando setado, o CRM trata
  /// name/email/phone/avatar como read-only (fonte autoritativa = User).
  /// Restrição 1:1 — cada User tem no máximo 1 Contact vinculado.
  userId         String?     @unique
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  /// Soft-delete: cards historicos ainda referenciam mesmo apos remover
  /// da agenda principal. Filtrar `deletedAt: null` no listing.
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent       Contact?      @relation("ContactPerson", fields: [parentId], references: [id], onDelete: SetNull)
  children     Contact[]     @relation("ContactPerson")
  user         User?         @relation("ContactUser", fields: [userId], references: [id], onDelete: SetNull)
  cards        CardContact[]

  @@index([organizationId, type])
  @@index([organizationId, name])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([parentId])
}

model CardContact {
  cardId    String
  contactId String
  createdAt DateTime @default(now())

  card    Card    @relation(fields: [cardId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@id([cardId, contactId])
  @@index([contactId])
}

// ==================== Labels ====================

// Um label pode ser global da Org (boardId nulo) ou local de um quadro.
// Na UI do MVP usamos labels por quadro; a coluna organizationId fica pra
// futuro "labels globais".
model Label {
  id             String   @id @default(cuid())
  organizationId String
  boardId        String?
  name           String
  color          String // hex, ex: "#EF4444"
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  board        Board?       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards        CardLabel[]

  @@index([organizationId])
  @@index([boardId])
}

model CardLabel {
  cardId  String
  labelId String
  card    Card   @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label  @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

// ==================== Checklists ====================

model Checklist {
  id        String   @id @default(cuid())
  cardId    String
  title     String
  position  Float
  createdAt DateTime @default(now())

  card        Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]
  automations Automation[]

  @@index([cardId])
}

/// Template de checklist reutilizável da Org. Permite salvar uma estrutura
/// (título + N items) e aplicar em qualquer card com 1 click. Usos comuns:
/// onboarding de cliente, checklist de revisão, etapas de produção.
///
/// `items` é um JSON array de strings (textos das tarefas). Não armazenamos
/// dueDate/assignee/priority — esses são contextuais e ficam pra ajuste pós-aplicar.
model ChecklistTemplate {
  id             String   @id @default(cuid())
  organizationId String
  title          String
  items          Json // Array<string> — textos das tarefas em ordem
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation("ChecklistTemplateCreator", fields: [createdById], references: [id])

  @@index([organizationId])
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  text        String
  isDone      Boolean   @default(false)
  position    Float
  dueDate     DateTime?
  priority    Priority  @default(NONE)
  assigneeId  String?
  doneAt      DateTime?
  doneById    String?
  /// Doc 49: configuração de recorrência. JSON com shape:
  ///   { freq: 'DAILY'|'WEEKLY'|'MONTHLY'|'YEARLY', interval: number,
  ///     weekdays?: number[] (0-6 Dom-Sáb pra WEEKLY), endsAt?: ISO date }
  /// Quando o item recorrente é concluído, o backend cria uma nova
  /// instância copiando text/assignee/priority/recurrence com nova dueDate
  /// calculada a partir da atual + recurrence. Sem dueDate ou sem recurrence
  /// → sem efeito (item normal).
  recurrence  Json?

  checklist   Checklist    @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  assignee    User?        @relation("ChecklistItemAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  doneBy      User?        @relation("ChecklistItemDoneBy", fields: [doneById], references: [id], onDelete: SetNull)
  automations Automation[]

  @@index([checklistId, position])
  @@index([assigneeId, dueDate, isDone]) // suporta query da home: tarefas do user X agrupadas por prazo
}

// ==================== Attachments ====================

model Attachment {
  id          String         @id @default(cuid())
  cardId      String
  commentId   String? // se setado, o anexo pertence a um comment (timeline). Null = anexo direto do card.
  uploaderId  String
  fileName    String
  mimeType    String
  sizeBytes   Int
  storageKey  String
  kind        AttachmentKind @default(FILE)
  embedded    Boolean        @default(false) // true = imagem embutida na descricao ou no body do comment (nao aparece na lista de anexos)
  externalUrl String?
  createdAt   DateTime       @default(now())

  card         Card     @relation("CardAttachments", fields: [cardId], references: [id], onDelete: Cascade)
  comment      Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  uploader     User     @relation(fields: [uploaderId], references: [id])
  coverOfCards Card[]   @relation("CardCover")

  @@index([cardId])
  @@index([commentId])
}

// ==================== Comments ====================

model Comment {
  id              String    @id @default(cuid())
  cardId          String
  authorId        String
  body            Json // Tiptap JSON (ou texto simples no MVP)
  mentions        String[] // userIds mencionados (denormalizado pra notificação)
  /// Self-ref pra replies. Threads sao planos: reply-de-reply vira filho
  /// do root (flatten no service). UI renderiza 1 nivel de indentacao.
  /// onDelete: SetNull pra preservar replies quando parent vira soft-delete.
  parentCommentId String?
  editedAt        DateTime?
  createdAt       DateTime  @default(now())
  deletedAt       DateTime?

  card        Card              @relation(fields: [cardId], references: [id], onDelete: Cascade)
  author      User              @relation(fields: [authorId], references: [id])
  attachments Attachment[]
  parent      Comment?          @relation("CommentReply", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies     Comment[]         @relation("CommentReply")
  reactions   CommentReaction[]

  @@index([cardId, createdAt])
  @@index([parentCommentId])
}

/// Reacao emoji a um Comment. Set fechado de emojis (validado no service):
/// 👍 ❤️ 😂 🎉 👀. Unique por (commentId, userId, emoji) garante que cada
/// usuario reage no maximo 1x com o mesmo emoji em cada comment — toggle
/// no client deleta a entry.
model CommentReaction {
  id        String   @id @default(cuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
}

// ==================== Activity (audit log) ====================

model Activity {
  id              String       @id @default(cuid())
  organizationId  String
  boardId         String?
  cardId          String?
  actorId         String?
  type            ActivityType
  payload         Json
  /// Quando a Activity foi criada por uma execução de automação, traz o
  /// AutomationRun correspondente. Null = ação manual de usuário.
  /// Crítico pra o fluxo de undo de aprovação: sabemos diferenciar
  /// "humano interveio" de "automação encadeada disparou".
  automationRunId String?
  createdAt       DateTime     @default(now())

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  card          Card?          @relation(fields: [cardId], references: [id], onDelete: Cascade)
  actor         User?          @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)
  automationRun AutomationRun? @relation(fields: [automationRunId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([cardId, createdAt])
  @@index([boardId, createdAt])
  @@index([automationRunId])
}

// ==================== Notifications ====================

model Notification {
  id             String           @id @default(cuid())
  userId         String
  organizationId String
  type           NotificationType
  title          String
  body           String?
  entityType     String?
  entityId       String?
  isRead         Boolean          @default(false)
  readAt         DateTime?
  createdAt      DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
}

/// Modelos de mensagem reutilizáveis em campos de template das automações
/// (WhatsApp, comentário). O conteúdo é texto Mustache com placeholders
/// `{{card.title}}` etc — resolvidos pela engine quando a automação roda.
///
/// Compartilhado por Org (todos os MEMBER+ veem). Edit/delete é do criador
/// OU OWNER/ADMIN. `type` discrimina onde o modelo aparece no autocomplete
/// do form (sem cross-pollution entre WhatsApp e comment).
model MessageTemplate {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  body           String
  type           String // 'whatsapp' | 'comment'
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdById], references: [id])

  @@index([organizationId, type])
}

/// Web Push subscription (PWA). Cada dispositivo (browser/PWA) que opta
/// por receber notificações push registra aqui sua subscription. Quando
/// uma Notification é criada, a engine de push percorre todas as subs do
/// user e dispara via web-push protocol.
///
/// `endpoint` é único globalmente (URL gerada pelo push service do
/// browser — Mozilla/Google/Apple/etc). Se uma sub virar 410 (Gone) ao
/// enviar, o registro é removido automaticamente.
model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String // chave pública do cliente (base64url)
  auth       String // segredo de auth (base64url)
  userAgent  String? // hint sobre o dispositivo
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ==================== Time tracking ====================

model TimeEntry {
  id             String          @id @default(cuid())
  cardId         String? // null = timer "livre" (sem card vinculado, criado pelo botao do header sem contexto)
  userId         String
  organizationId String
  startedAt      DateTime
  endedAt        DateTime? // null = sessão ativa
  durationSec    Int? // gravado no stop, fonte da verdade pra agregações
  source         TimeEntrySource @default(TIMER)
  note           String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  card         Card?        @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([cardId, startedAt])
  @@index([userId, startedAt])
  @@index([organizationId, startedAt])
  @@index([userId, endedAt]) // achar entry ativa do user em O(1)
}

// ==================== Card visits ====================

// Track de cards abertos pelo user. Alimenta a "Cards recentes" da home.
// 1 row por (user, card) — atualizado em vez de inserido pra evitar bloat.
model CardVisit {
  userId    String
  cardId    String
  visitedAt DateTime @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@id([userId, cardId])
  @@index([userId, visitedAt(sort: Desc)])
}

// ==================== Tasks ====================

// Tarefas standalone (sem vinculo a card). Aparecem na home pessoal junto
// com os ChecklistItems, mas sao de nivel da Org. Quem cria atribui pra
// si por padrao mas pode reatribuir.
model Task {
  id             String    @id @default(cuid())
  organizationId String
  text           String
  isDone         Boolean   @default(false)
  dueDate        DateTime?
  position       Float     @default(0)
  assigneeId     String?
  createdById    String
  doneAt         DateTime?
  doneById       String?
  /// Doc 49: mesmo shape de ChecklistItem.recurrence. Quando a Task
  /// recorrente é concluída, cria nova com nova dueDate.
  recurrence     Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignee     User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  createdBy    User         @relation("TaskCreator", fields: [createdById], references: [id])
  doneBy       User?        @relation("TaskDoneBy", fields: [doneById], references: [id], onDelete: SetNull)

  @@index([organizationId, assigneeId, isDone])
  @@index([organizationId, dueDate])
}

// ==================== Automations ====================

/// Regra automatizada vinculada a uma list/board/org. Quando o trigger
/// dispara, a engine cria um AutomationRun e processa a action.
/// MVP: escopo principal é por LIST. Board/Org são preparação pra Fase 2+.
model Automation {
  id                   String               @id @default(cuid())
  organizationId       String
  listId               String?
  boardId              String?
  /// Doc 48: escopo de checklist quando trigger=CHECKLIST_COMPLETED.
  /// Mutex com listId pro mesmo registro.
  scopeChecklistId     String?
  /// Doc 48: escopo de item quando trigger=CHECKLIST_ITEM_DONE.
  scopeChecklistItemId String?
  trigger              AutomationTrigger
  /// Configuração do gatilho. Ex: { minutes: 60 } pra TIME_IN_LIST.
  triggerConfig        Json                 @default("{}")
  actionType           AutomationActionType
  /// Payload específico da action. Ex: { tagIds: ["..."] } pra INSERT_TAGS.
  actionConfig         Json                 @default("{}")
  isActive             Boolean              @default(true)
  /// Configuração condicional (AND entre todas). Cada item é um
  /// AutomationCondition (ver dto). Null/undefined = sempre roda.
  /// Avaliado em executeAutomation antes de chamar a action.
  conditions           Json?
  /// Label opcional pra o usuário identificar a automação na lista
  /// (ex: "Marcar como urgente quando entrar em A fazer").
  label                String?
  createdById          String
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  organization       Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  list               List?           @relation(fields: [listId], references: [id], onDelete: Cascade)
  board              Board?          @relation(fields: [boardId], references: [id], onDelete: Cascade)
  scopeChecklist     Checklist?      @relation(fields: [scopeChecklistId], references: [id], onDelete: Cascade)
  scopeChecklistItem ChecklistItem?  @relation(fields: [scopeChecklistItemId], references: [id], onDelete: Cascade)
  createdBy          User            @relation("AutomationCreator", fields: [createdById], references: [id])
  runs               AutomationRun[]
  failures           AutomationFailure[]

  @@index([organizationId])
  @@index([listId, isActive])
  @@index([boardId, isActive])
  @@index([scopeChecklistId, isActive])
  @@index([scopeChecklistItemId, isActive])
}

/// Histórico de execução de uma automação. Cada run referencia (quando
/// aplicável) o card que disparou. `chainDepth` ajuda no anti-loop.
model AutomationRun {
  id           String              @id @default(cuid())
  automationId String
  cardId       String?
  status       AutomationRunStatus @default(PENDING)
  /// Quantos saltos esta run está dentro de uma cadeia de automações
  /// disparadas em sequência. Engine aborta acima de 5 (anti-loop).
  chainDepth   Int                 @default(0)
  error        String?
  /// Resultado/payload do que foi feito (pra debug e auditoria).
  result       Json?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime            @default(now())

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
  card       Card?      @relation(fields: [cardId], references: [id], onDelete: SetNull)
  activities Activity[]

  @@index([automationId, createdAt])
  @@index([cardId])
}

/// Outbox transacional de triggers de automação. Persistida na mesma
/// transação que altera o card/checklist garante que o evento NÃO se
/// perde mesmo que o processo morra/reinicie entre o COMMIT e a
/// execução da automação (problema antigo do EventEmitter2 in-process).
///
/// Processada por:
///   - Push: fire-and-forget logo após o COMMIT (latência baixa).
///   - Pull: cron a cada 5s lê pendentes cujo nextAttemptAt <= now()
///     com `SELECT ... FOR UPDATE SKIP LOCKED` (cobre push perdido +
///     escala pra multi-worker).
///
/// Idempotência:
///   - `processedAt` setado = sucesso ou esgotou retries (dead-letter).
///   - Retry backoff: 30s → 2min → 10min. Após `MAX_ATTEMPTS`, cria
///     AutomationFailure e marca processedAt pra sair do polling.
model AutomationOutbox {
  id             String                @id @default(cuid())
  organizationId String
  /// Trigger semântico que casa com Automation.trigger durante o dispatch.
  trigger        AutomationTrigger
  cardId         String
  /// Tipo do escopo onde o trigger nasceu (lista, checklist ou item).
  scopeKind      AutomationOutboxScope
  /// FK lógica pra List/Checklist/ChecklistItem conforme scopeKind.
  /// Não usa @relation pra evitar cascade quando a entidade some — se a
  /// lista for deletada antes do processamento, a row vira no-op silencioso.
  scopeId        String
  /// Herdado da automação-pai pra anti-loop (engine aborta acima de 5).
  chainDepth     Int                   @default(0)
  /// Tentativas já executadas. Incrementa a cada erro; quando atinge o
  /// teto, vira AutomationFailure e processedAt é setado.
  attempts       Int                   @default(0)
  /// Quando rodar de novo (now() pra nova entry; futuro pra backoff).
  nextAttemptAt  DateTime              @default(now())
  /// Último erro encontrado (truncado se muito longo). Diagnóstico.
  lastError      String?
  /// Setado = processado (sucesso OU esgotou retries). Cron filtra por null.
  processedAt    DateTime?
  createdAt      DateTime              @default(now())

  /// Polling do cron: where processedAt IS NULL and nextAttemptAt <= now()
  /// ordenado por createdAt (FIFO). Índice parcial seria ideal mas o
  /// Prisma não suporta — composto cobre o suficiente.
  @@index([processedAt, nextAttemptAt])
  @@index([organizationId, createdAt])
  @@index([cardId])
}

/// Dead-letter consolidada: 1 entry por evento de automação que falhou
/// definitivamente (após retries esgotados). Mantém payload pra
/// reprocessamento manual via painel admin.
model AutomationFailure {
  id              String               @id @default(cuid())
  organizationId  String
  automationId    String
  cardId          String
  /// FK pro AutomationRun da última tentativa. Pode ser null se nem
  /// chegou a criar o run (ex: automation foi deletada entre enqueue
  /// e processamento).
  runId           String?
  trigger         AutomationTrigger
  actionType      AutomationActionType
  attempts        Int
  errorMessage    String
  errorStack      String?
  /// Snapshot do outbox row (trigger/scope/chainDepth) pra reprocessar
  /// sem depender do estado atual do banco.
  payloadSnapshot Json
  createdAt       DateTime             @default(now())
  /// Setado quando admin marca como resolvido (manual ou após reprocesso
  /// bem-sucedido). Filtro do painel exclui já-resolvidos por default.
  resolvedAt      DateTime?
  resolvedById    String?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([organizationId, resolvedAt, createdAt])
  @@index([automationId])
  @@index([cardId])
}

/// Auditoria de cada envio de cobranca de aprovacao. 1 linha por
/// (envio, reviewer) — quando o cron manda lembrete consolidado pra 3
/// reviewers, gera 3 logs. Permite responder:
///   - Quantas vezes esse card foi cobrado? (count por approvalId)
///   - Anna recebeu quantos lembretes do card X? (filter por approval+reviewer)
///   - WhatsApp tá falhando? (filter por channel + success=false)
///
/// Sem retencao automatica — admin limpa manualmente se quiser. Volume
/// esperado eh baixo (~20 envios/dia em uso normal).
model ApprovalDispatchLog {
  id             String                  @id @default(cuid())
  organizationId String
  approvalId     String
  /// Reviewer destinatario. Pode ser null quando o envio foi pra phone
  /// externo (sem User cadastrado).
  reviewerUserId String?
  /// Telefone destino (E.164 sem '+'). Preenchido pra WhatsApp; null pra in-app.
  phone          String?
  /// Nome display do destinatario no momento do envio (snapshot).
  /// Pra interno = User.name; pra externo = externalName ou phone.
  recipientName  String
  kind           ApprovalDispatchKind
  channel        ApprovalDispatchChannel
  /// true = aceito pela Evolution / criado o Notification.
  /// false = erro (timeout, 5xx Evolution, NotificationsService throw).
  success        Boolean
  /// Mensagem de erro quando success=false. Truncada a 500 chars.
  errorMessage   String?
  /// Quando relevante: snapshot do texto/título enviado (trunc 1000 chars).
  /// Util pra auditar conteudo posterior. Null se nao guardamos.
  preview        String?
  createdAt      DateTime                @default(now())

  approval CardApproval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  reviewer User?        @relation(fields: [reviewerUserId], references: [id], onDelete: SetNull)

  /// Indice principal: painel de historico por org, mais recente primeiro.
  @@index([organizationId, createdAt])
  /// Drill-down por approval (timeline do card).
  @@index([approvalId, createdAt])
  /// Drill-down por reviewer ("quantas cobrancas a Anna recebeu?").
  @@index([reviewerUserId, createdAt])
  /// Filtro de falhas (success=false + canal).
  @@index([organizationId, success, channel])
}

// ==================== Import mappings ====================

/// Memoria de mapeamentos de importacao por Org. Quando o user mapeia
/// "Thiago" (vindo do CSV Ummense) -> Thiago Bueno (User do KTask) na
/// pagina /configuracoes/importar, persistimos aqui pra que o proximo
/// import com o mesmo nome ja chegue pre-mapeado. UPSERT por
/// (organizationId, kind, sourceName) — sobrescreve se ja existe.
///
/// targetId nullable: null = "Ignorar" persistido (cards sem esse
/// member/lista; nao perguntar de novo). Pra kind='list', targetId
/// pode tambem indicar "criar com este nome" via convencao especial?
/// Nao — pra criar nova lista, NAO persiste o mapping (lista ja existe
/// depois de criada, virando match exato no proximo import).
model OrgImportMapping {
  id             String   @id @default(cuid())
  organizationId String
  /// 'user' ou 'list'. String solta em vez de enum pra permitir extensao
  /// futura ('label', 'contact') sem migration de enum.
  kind           String
  /// Nome como veio do CSV, nao normalizado. Match exato no lookup.
  sourceName     String
  /// FK pro target (UserId pra kind='user', ListId pra kind='list').
  /// Null = decisao explicita do user de "Ignorar este nome".
  targetId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, kind, sourceName])
  @@index([organizationId, kind])
}

// ==================== Federacao de Identidade (KTask como IdP) ====================

/// Cliente externo da plataforma KTask atuando como Service Provider (SP) na
/// federacao OAuth2/OIDC simplificada onde KTask eh o Identity Provider (IdP).
/// Sistemas registrados aqui podem validar credenciais via POST /auth/validate
/// e recebem webhooks assinados em mudancas de usuario/organizacao.
/// Detalhes em tarefas-md/51-federacao-idp-para-ogma.md.
model ServiceProvider {
  id           String   @id @default(cuid())
  /// Nome exibido no admin global, ex: "Ogma - Atendimento Creatyze"
  nome         String
  /// Slug unico, ex: "ogma". Usado em logs e como referencia externa.
  slug         String   @unique
  /// URL onde os webhooks sao entregues, ex:
  /// "https://ogma.creatyze.com.br/api/webhooks/ktask"
  webhookUrl   String
  /// SHA-256 do secret HMAC. O secret em plaintext eh mostrado 1 vez ao
  /// admin global na criacao; nao armazenamos plaintext.
  secretHash   String
  /// Eventos que esse SP recebe. Lista de strings, ex:
  /// ["usuario.email_alterado", "usuario.senha_alterada", "usuario.desativado"]
  escopo       String[]
  /// Quando false, webhooks nao sao despachados.
  ativo        Boolean  @default(true)
  /// Observacoes livres do admin (contato responsavel, proposito, etc).
  notas        String?
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt
}

// ==================== Visão Gerencial — Kanban virtual ====================
// Colunas virtuais que agregam cards de listas de quadros diferentes numa
// lente de leitura pra gestao (OWNER/ADMIN/GESTOR). Read-only — nao move
// cards. Ver tarefas-md/visao-gerencial-kanban.md.

/// Uma "visao" Kanban gerencial da org. V1 usa 1 por org (auto-criada no
/// primeiro acesso), mas o modelo ja suporta N (multi-visao no futuro).
model ManagementBoard {
  id             String   @id @default(cuid())
  organizationId String
  name           String   @default("Visão Kanban")
  position       Float    @default(0)
  createdById    String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  columns      ManagementColumn[]

  @@index([organizationId])
}

/// Coluna virtual ("A fazer", "Fazendo", etc). Ordem via position.
model ManagementColumn {
  id                String   @id @default(cuid())
  managementBoardId String
  name              String
  position          Float
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  managementBoard ManagementBoard          @relation(fields: [managementBoardId], references: [id], onDelete: Cascade)
  sources         ManagementColumnSource[]

  @@index([managementBoardId, position])
}

/// Fonte de uma coluna virtual: um par (board, list). Os cards presentes
/// nessa lista aparecem na coluna. FK com cascade — lista/board apagado
/// limpa a fonte automaticamente (sem referencia fantasma).
model ManagementColumnSource {
  id       String @id @default(cuid())
  columnId String
  boardId  String
  listId   String

  column ManagementColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  board  Board            @relation(fields: [boardId], references: [id], onDelete: Cascade)
  list   List             @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@unique([columnId, boardId, listId])
  @@index([columnId])
  @@index([listId])
}
