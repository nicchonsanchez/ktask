# ----------- Core -----------
NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

# ----------- Database -----------
DATABASE_URL=postgresql://ktask:ktask@localhost:5433/ktask?schema=public

# ----------- Cache / Queues -----------
REDIS_URL=redis://localhost:6379

# ----------- Auth -----------
# gere com: openssl rand -hex 32
JWT_ACCESS_SECRET=change-me-please-at-least-16-chars
JWT_REFRESH_SECRET=also-change-me-at-least-16-chars
JWT_ACCESS_TTL=15m
# Quando "Permanecer logado" marcado (default no login)
JWT_REFRESH_TTL=90d
# Quando "Permanecer logado" DESMARCADO (equipamento compartilhado)
JWT_REFRESH_TTL_SHORT=1d

# ----------- CORS -----------
CORS_ORIGINS=http://localhost:3000

# ----------- Storage (MinIO em dev) -----------
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=ktask-attachments
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniominio
S3_PUBLIC_URL=http://localhost:9000/ktask-attachments

# ----------- E-mail (Mailpit em dev) -----------
EMAIL_FROM="KTask <noreply@ktask.local>"
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=

# ----------- Evolution API (WhatsApp) -----------
# Em produção a config fica por Organização em Integration.config (criptografada).
# Estes defaults só são usados em dev ou como fallback.
EVOLUTION_DEFAULT_URL=
EVOLUTION_DEFAULT_API_KEY=
EVOLUTION_DEFAULT_INSTANCE=

# Numero do operador (quem recebe alertas do Modo Independente etc).
# Formato E.164 sem '+', ex: 5531993767301
OPERATOR_PHONE=

# ----------- Criptografia -----------
# 64 caracteres hex (32 bytes). Gerar com: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# ----------- Web Push (PWA notifications) -----------
# Gerar com: cd apps/api && node -e "console.log(JSON.stringify(require('web-push').generateVAPIDKeys()))"
# A publickey também precisa estar em NEXT_PUBLIC_VAPID_PUBLIC_KEY no apps/web/.env
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:noreply@ktask.local

# ----------- Observabilidade -----------
SENTRY_DSN=
